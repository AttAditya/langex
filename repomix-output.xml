<file path="pyproject.toml">
[build-system]
requires = ["setuptools>=68", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "langex"
version = "0.1.0"
description = "Extended Language Support for Python"
requires-python = ">=3.14"
authors = [
  { name = "AttAditya" }
]

[project.scripts]
langex = "langex.__main__:main"

[tool.setuptools.packages.find]
where = ["."]
include = ["langex*"]
</file>

<file path="rc.sh">
source ./.venv/bin/activate

lnx() {
  fmt() {
    python -m formatter.fmt $@
  }

  run() {
    python -m langex $@
  }

  sample() {
    python samples$1
  }

  if [ "$1" = "fmt" ]; then
    shift
    fmt $@
  elif [ "$1" = "run" ]; then
    shift
    run $@
  else
    echo "Possible commands: fmt, run"
  fi
}
</file>

